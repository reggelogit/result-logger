<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F1A"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Result Logger"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E8E8FF"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="4dp"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Írj értéket a results.txt fájlba"
        android:textSize="13sp"
        android:textColor="#8888AA"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- Button: Write 10 -->
        <Button
            android:id="@+id/btnTen"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="10"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3D2FBF"
            android:stateListAnimator="@null"
            android:elevation="4dp"
            style="@style/Widget.MaterialComponents.Button" />

        <!-- Button: Write 1 -->
        <Button
            android:id="@+id/btnOne"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="1"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#BF2F6A"
            android:stateListAnimator="@null"
            android:elevation="4dp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

    <!-- File path info -->
    <TextView
        android:id="@+id/tvFilePath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📄 Fájl: ..."
        android:textSize="11sp"
        android:textColor="#6666AA"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <!-- Log label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NAPLÓ (utolsó 15 sor)"
        android:textSize="11sp"
        android:textColor="#8888AA"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <!-- Log scroll view -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1A1A2E"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(fájl még nem létezik)"
            android:textSize="12sp"
            android:textColor="#AAAACC"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp" />

    </ScrollView>

</LinearLayout>
